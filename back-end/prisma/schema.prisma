
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 🔐 ENUM UNTUK ROLE PENGGUNA
enum Role {
  SUPER_ADMIN
  SHELTER
  DONATUR
}

// 🏡 ENUM UNTUK STATUS VERIFIKASI SHELTER
enum ShelterVerificationStatus {
  PENDING   
  APPROVED  
  REJECTED  
}


enum DonationStatus {
  PENDING   
  APPROVED  
  REJECTED  
  CANCELLED 
}


enum AdoptionStatus {
  ACTIVE    
  CANCELLED 
  EXPIRED   
}


model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String    // Kata sandi wajib di-hash dengan bcrypt pada backend
  role              Role      @default(DONATUR)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? 

  donaturProfile    Donatur?
  shelterProfile    Shelter?
  verifiedDonations Donasi[]  @relation("TransactionVerifier")
}

// 👤 2. TABEL PROFIL DONATUR
model Donatur {
  id          String           @id @default(uuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phoneNumber String?
  address     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?        // 🛡️ IMPLEMENTASI SOFT DELETE

  donations   Donasi[]
  adoptions   AdoptionPeriod[]
  comments    Comment[]
  wishlists   Wishlist[]
}

// 🏡 3. TABEL PROFIL SHELTER
model Shelter {
  id                 String                    @id @default(uuid())
  userId             String                    @unique
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  description        String                    @db.Text
  city               String                    
  address            String
  contactNo          String                  
  bankAccount        String                    
  verificationStatus ShelterVerificationStatus @default(PENDING)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deletedAt          DateTime?                

  animals            Hewan[]
}


model Hewan {
  id             String           @id @default(uuid())
  shelterId      String
  shelter        Shelter          @relation(fields: [shelterId], references: [id], onDelete: Cascade)
  name           String
  type           String          
  description    String           @db.Text
  foodCost       Float           
  medicalCost    Float            
  slotsAvailable Int              @default(3) 
  photoUrl       String           
  status         String           @default("BUTUH_ASUHAN")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?       

  donations      Donasi[]
  reports        Report[]
  adoptions      AdoptionPeriod[]
  wishlists      Wishlist[]
}

// ⏳ 5. TABEL REKAM JEJAK MASA ASUH DIGITAL
model AdoptionPeriod {
  id        String         @id @default(uuid())
  donaturId String
  donatur   Donatur        @relation(fields: [donaturId], references: [id], onDelete: Cascade)
  hewanId   String
  hewan     Hewan          @relation(fields: [hewanId], references: [id], onDelete: Cascade)
  startDate DateTime       @default(now())
  endDate   DateTime      
  status    AdoptionStatus @default(ACTIVE) 
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// 📊 6. TABEL RIWAYAT TRANSAKSI DONASI
model Donasi {
  id           String         @id @default(uuid())
  donaturId    String
  donatur      Donatur        @relation(fields: [donaturId], references: [id], onDelete: Cascade)
  hewanId      String
  hewan        Hewan          @relation(fields: [hewanId], references: [id], onDelete: Cascade)
  amount       Float         
  platformFee  Float          
  netAmount    Float          
  proofUrl     String        
  status       DonationStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?     

  verifiedById String?        
  verifiedBy   User?          @relation("TransactionVerifier", fields: [verifiedById], references: [id])
}

// 📰 7. TABEL LAPORAN PERKEMBANGAN
model Report {
  id        String    @id @default(uuid())
  hewanId   String
  hewan     Hewan     @relation(fields: [hewanId], references: [id], onDelete: Cascade)
  title     String
  content   String    @db.Text
  photoUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  comments  Comment[]
}

// 🔀 8. JUNCTION TABLE 1: COMMENT
model Comment {
  id        String    @id @default(uuid())
  reportId  String
  report    Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  donaturId String
  donatur   Donatur   @relation(fields: [donaturId], references: [id], onDelete: Cascade)
  text      String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? 
}

// 🔀 9. JUNCTION TABLE 2: WISHLIST
model Wishlist {
  id        String   @id @default(uuid())
  donaturId String
  donatur   Donatur  @relation(fields: [donaturId], references: [id], onDelete: Cascade)
  hewanId   String
  hewan     Hewan    @relation(fields: [hewanId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([donaturId, hewanId])
}